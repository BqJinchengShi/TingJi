# === ASR 鉴权（新版 / 旧版二选一）===
# 新版控制台（推荐）：火山引擎控制台 -> 语音技术 -> API Key 管理
DOUBAO_API_KEY=

# 旧版控制台（与上面互斥，二选一）
# DOUBAO_APP_ID=
# DOUBAO_ACCESS_TOKEN=

# === TOS 对象存储（音频上传拿公网 URL）===
# 火山引擎 TOS AK/SK（主账号或子账号密钥）
TOS_AK=
TOS_SK=
TOS_BUCKET=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com

# === 其他（可选）===
# user.uid，提交 ASR 时的用户标识，默认 doubao-recorder
# DOUBAO_UID=doubao-recorder
